generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  CEO
  REGIONAL_DIRECTOR
  SECTOR_DIRECTOR
  SITE_DIRECTOR
  SALES_MANAGER
  SALES_REP
}

/// Theme par defaut de l interface pour cette organisation.
enum Theme {
  LIGHT
  DARK
  AUTO
}

enum ProspectStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  INACTIVE
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

// ============================================================
// ORGANISATION MULTI-TENANT — WHITE LABEL
// ============================================================

/// Entreprise cliente (tenant SaaS) et coeur du moteur White Label.
/// Chaque organisation est completement isolee.
/// Les champs White Label permettent a chaque client de personnaliser
/// son identite visuelle, son domaine, et ses parametres regionaux.
model Organization {
  id   String @id @default(uuid())

  // --- Identite ---
  /// Nom interne (utilise par l equipe EBH pour identifier le client)
  name        String
  /// Nom affiche dans l interface (peut etre different du nom interne)
  displayName String?
  /// Slug unique pour les URLs et l identification du tenant
  slug        String  @unique
  /// Slogan ou baseline de l entreprise
  tagline     String?

  // --- Branding visuel ---
  /// URL du logo principal (format rectangle, fond transparent recommande)
  logoUrl        String?
  /// URL du logo compact (carre ou icone, pour sidebar collapsed, favicon fallback)
  logoCompactUrl String?
  /// URL du favicon (format .ico ou .png 32x32)
  faviconUrl     String?
  /// URL de l image affichee sur la page de connexion
  loginImageUrl  String?
  /// Couleur principale (hex, ex: "#3B82F6")
  primaryColor   String? @default("#3B82F6")
  /// Couleur secondaire (hex, ex: "#1E40AF")
  secondaryColor String? @default("#1E40AF")
  /// Couleur d accent (hex, ex: "#F59E0B")
  accentColor    String? @default("#F59E0B")
  /// Theme par defaut de l interface
  defaultTheme   Theme   @default(LIGHT)

  // --- Contact et support ---
  /// Site web de l entreprise cliente
  website      String?
  /// Email de support affiche dans l application
  supportEmail String?
  /// Telephone de support affiche dans l application
  supportPhone String?

  // --- Domaine personnalise ---
  /// Domaine personnalise du client (ex: crm.monentreprise.fr)
  /// null = utilisation du domaine EBH par defaut
  customDomain String? @unique

  // --- Parametres regionaux ---
  /// Code langue ISO 639-1 (ex: "fr", "en", "es")
  language   String @default("fr")
  /// Fuseau horaire IANA (ex: "Europe/Paris", "America/New_York")
  timezone   String @default("Europe/Paris")
  /// Code devise ISO 4217 (ex: "EUR", "USD", "GBP")
  currency   String @default("EUR")
  /// Format de date (ex: "DD/MM/YYYY", "MM/DD/YYYY", "YYYY-MM-DD")
  dateFormat String @default("DD/MM/YYYY")
  /// Separateur decimal (ex: "," pour fr, "." pour en)
  numberFormat String @default(",")

  // --- Contenu legal et navigation ---
  /// URL de la politique de confidentialite
  privacyPolicyUrl String?
  /// URL des CGU
  termsUrl         String?
  /// URL du footer (lien vers le site institutionnel)
  footerLink       String?
  /// Texte du footer (ex: "Propulse par EBH Pilot" ou nom de marque)
  footerText       String?

  // --- Controle White Label ---
  /// Active les fonctionnalites White Label (domaine, logo, couleurs)
  isWhiteLabelEnabled Boolean @default(false)
  /// Active ou desactive l organisation entiere
  isActive            Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessUnits BusinessUnit[]
  regions       Region[]
  users         User[]

  @@index([slug])
  @@index([customDomain])
}

/// Division, marque, enseigne ou filiale appartenant a une organisation.
model BusinessUnit {
  id             String       @id @default(uuid())
  name           String
  code           String?
  description    String?
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  regions        Region[]
  users          User[]

  @@index([organizationId])
}

/// Region geographique appartenant a une organisation.
model Region {
  id             String        @id @default(uuid())
  name           String
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessUnitId String?
  businessUnit   BusinessUnit? @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  sectors        Sector[]
  users          User[]

  @@index([organizationId])
  @@index([businessUnitId])
}

/// Secteur commercial appartenant a une region.
model Sector {
  id        String   @id @default(uuid())
  name      String
  regionId  String
  region    Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sites     Site[]
  users     User[]

  @@index([regionId])
}

/// Site physique ou point de vente appartenant a un secteur.
model Site {
  id        String   @id @default(uuid())
  name      String
  address   String?
  city      String?
  sectorId  String
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  @@index([sectorId])
}

// ============================================================
// UTILISATEURS ET HIERARCHIE
// ============================================================

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  name     String?
  authId   String?  @unique
  role     UserRole @default(SALES_REP)
  isActive Boolean  @default(true)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  businessUnitId String?
  businessUnit   BusinessUnit? @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)

  regionId String?
  region   Region? @relation(fields: [regionId], references: [id], onDelete: SetNull)

  sectorId String?
  sector   Sector? @relation(fields: [sectorId], references: [id], onDelete: SetNull)

  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  managerId    String?
  manager      User?  @relation("UserHierarchy", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates User[] @relation("UserHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedProspects  Prospect[]  @relation("ProspectOwner")
  ownedProducts   Product[]   @relation("ProductOwner")
  ownedImportJobs ImportJob[] @relation("ImportJobOwner")

  @@index([organizationId])
  @@index([businessUnitId])
  @@index([managerId])
  @@index([role])
  @@index([siteId])
}

// ============================================================
// DONNEES METIER
// ============================================================

model Prospect {
  id           String         @id @default(uuid())
  name         String
  company      String?
  email        String?
  value        Decimal        @default(0) @db.Decimal(12, 2)
  status       ProspectStatus @default(NEW)
  contactName  String?
  phone        String?
  mobile       String?
  website      String?
  address      String?
  postalCode   String?
  city         String?
  country      String?
  vatNumber    String?
  clientStatus ClientStatus   @default(PROSPECT)
  notes        String?
  ownerId      String
  owner        User           @relation("ProspectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([ownerId])
}

model Product {
  id                String   @id @default(uuid())
  name              String
  brand             String?
  supplier          String?
  supplierReference String?
  purchasePrice     Decimal  @default(0) @db.Decimal(12, 2)
  transportCost     Decimal  @default(0) @db.Decimal(12, 2)
  preparationCost   Decimal  @default(0) @db.Decimal(12, 2)
  accessoriesCost   Decimal  @default(0) @db.Decimal(12, 2)
  otherCosts        Decimal  @default(0) @db.Decimal(12, 2)
  costPrice         Decimal  @default(0) @db.Decimal(12, 2)
  sellingPrice      Decimal  @default(0) @db.Decimal(12, 2)
  marginAmount      Decimal  @default(0) @db.Decimal(12, 2)
  marginPercent     Decimal  @default(0) @db.Decimal(7, 2)
  ownerId           String
  owner             User     @relation("ProductOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([ownerId])
}

model ImportJob {
  id        String          @id @default(uuid())
  url       String
  status    ImportJobStatus @default(PENDING)
  ownerId   String?
  owner     User?           @relation("ImportJobOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([ownerId])
}

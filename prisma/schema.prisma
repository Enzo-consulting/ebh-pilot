generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS — Core
// ============================================================

enum UserRole {
  CEO
  REGIONAL_DIRECTOR
  SECTOR_DIRECTOR
  SITE_DIRECTOR
  SALES_MANAGER
  SALES_REP
}

enum Theme {
  LIGHT
  DARK
  AUTO
}

enum ProspectStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  INACTIVE
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

// ============================================================
// ENUMS — Module Engine (Ticket 016)
// ============================================================

enum ModuleCategory {
  SALES
  OPERATIONS
  FINANCE
  HR
  ANALYTICS
  AI
  INTEGRATION
  COMMUNICATION
  DOCUMENTS
  MOBILE
}

enum FeatureCode {
  AI_TRANSLATION
  AI_ANALYSIS
  AI_IMPORT
  AI_ASSISTANT
  PDF_GENERATION
  EXPORT_EXCEL
  EXPORT_PDF
  DOCUMENTS
  EMAILING
  SMS
  WHATSAPP
  PUSH_NOTIFICATIONS
  YOUSIGN
  DOCUSIGN
  API_ACCESS
  WEBHOOK
  REPORTING
  ADVANCED_ANALYTICS
  CUSTOM_DASHBOARDS
  MOBILE_APP
  GPS_TRACKING
  QR_SCAN
  BARCODE_SCAN
  OFFLINE_MODE
  CUSTOM_DOMAIN
  WHITE_LABEL
  CHALLENGES
  LEADERBOARD
  AUDIT_LOG
  MULTI_ORGANIZATION
  SSO
}

// ============================================================
// ENUMS — Audit Engine (Ticket 018)
// ============================================================

enum DomainEventType {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  PROSPECT_CREATED
  PROSPECT_UPDATED
  PROSPECT_DELETED
  CLIENT_CREATED
  CLIENT_UPDATED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  IMPORT_STARTED
  IMPORT_COMPLETED
  IMPORT_FAILED
  DOCUMENT_GENERATED
  DOCUMENT_SIGNED
  TASK_CREATED
  TASK_COMPLETED
  AI_REQUESTED
  AI_COMPLETED
  WORKFLOW_STARTED
  WORKFLOW_FINISHED
  NOTIFICATION_CREATED
  LOGIN_SUCCESS
  LOGIN_FAILED
  MODULE_ENABLED
  FEATURE_ENABLED
  // ── Performance & Progression (Ticket 020 / 021C) ───────────────────────
  KPI_RECORDED
  BADGE_EARNED
  CHALLENGE_COMPLETED
  GOAL_REACHED
  SEASON_STARTED
  SEASON_ENDED
  // ── Progression Engine (Ticket 021C) ─────────────────────────────────────
  XP_GAINED
  XP_REMOVED
  USER_LEVEL_UP
  USER_NEW_TITLE
}

// ============================================================
// ENUMS — Tenant Config Engine (Ticket 019)
// ============================================================

enum SettingCategory {
  GENERAL
  LOCALE
  FISCAL
  NUMBERING
  DOCUMENT
  EMAIL
  NOTIFICATION
  WORKFLOW
  AI
  QUOTA
  BRANDING
  SECURITY
  INTEGRATION
  MOBILE
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  DATE
  COLOR
  URL
  EMAIL
  PHONE
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  WHATSAPP
  TEAMS
  SLACK
  DISCORD
  IN_APP
  WEBHOOK
}

enum IntegrationProvider {
  OPENAI
  ANTHROPIC
  GEMINI
  MISTRAL
  AZURE_OPENAI
  STRIPE
  PENNYLANE
  YOUSIGN
  DOCUSIGN
  GOOGLE_WORKSPACE
  MICROSOFT_365
  ZAPIER
  WEBHOOK_CUSTOM
  TWILIO
  SENDGRID
  RESEND
  MAILGUN
  VONAGE
  INTERCOM
  HUBSPOT
  SALESFORCE
  PIPEDRIVE
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  EXPIRED
  PENDING_SETUP
}

// ============================================================
// ENUMS — Performance Engine (Ticket 020)
// ============================================================

enum KpiUnit {
  COUNT
  CURRENCY
  PERCENTAGE
  DURATION
  SCORE
  RATIO
  CUSTOM
}

enum KpiCalculationType {
  SUM
  AVERAGE
  COUNT
  MAX
  MIN
  LAST
  WEIGHTED
  CUSTOM
}

enum KpiAggregation {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  SEASON
  CUSTOM
}

enum LeaderboardScope {
  PERSONAL
  TEAM
  SITE
  SECTOR
  REGION
  BUSINESS_UNIT
  ORGANIZATION
  NATIONAL
  INTERNATIONAL
}

enum LeaderboardType {
  RANKING
  SCORE
  POINTS
  STREAK
  ACHIEVEMENT
}

enum BadgeTriggerType {
  KPI_THRESHOLD
  LEADERBOARD_RANK
  STREAK
  CHALLENGE_WIN
  GOAL_REACHED
  FIRST_TIME
  MANUAL
  SEASONAL
  LEVEL_UP
  ANNIVERSARY
}

enum BadgeRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum ChallengeStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum ChallengeType {
  INDIVIDUAL
  TEAM
  COOPERATIVE
  PERSONAL
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
  PAUSED
}
// ============================================================
// ORGANISATION MULTI-TENANT — WHITE LABEL (Ticket 014)
// ============================================================

model Organization {
  id                  String   @id @default(uuid())
  name                String
  displayName         String?
  slug                String   @unique
  tagline             String?
  logoUrl             String?
  logoCompactUrl      String?
  faviconUrl          String?
  loginImageUrl       String?
  primaryColor        String?  @default("#3B82F6")
  secondaryColor      String?  @default("#1E40AF")
  accentColor         String?  @default("#F59E0B")
  defaultTheme        Theme    @default(LIGHT)
  website             String?
  supportEmail        String?
  supportPhone        String?
  customDomain        String?  @unique
  language            String   @default("fr")
  timezone            String   @default("Europe/Paris")
  currency            String   @default("EUR")
  dateFormat          String   @default("DD/MM/YYYY")
  numberFormat        String   @default(",")
  privacyPolicyUrl    String?
  termsUrl            String?
  footerLink          String?
  footerText          String?
  isWhiteLabelEnabled Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  businessUnits         BusinessUnit[]
  regions               Region[]
  users                 User[]
  modules               OrganizationModule[]
  features              OrganizationFeature[]
  auditEvents           AuditEvent[]
  settings              OrganizationSetting[]
  workflowTemplates     WorkflowTemplate[]
  notificationTemplates NotificationTemplate[]
  integrations          OrganizationIntegration[]
  kpiDefinitions        KpiDefinition[]
  leaderboards          Leaderboard[]
  badges                Badge[]
  challenges            Challenge[]
  goals                 Goal[]
  seasons               Season[]
  leagueDefinitions     LeagueDefinition[]
  userLeagues           UserLeague[]
  userLeaguePeaks       UserLeaguePeak[]
  hallOfFameEntries     HallOfFameEntry[]
  publicProfiles        UserPublicProfile[]
  profileFieldVisibilities ProfileFieldVisibility[]
  profileVisits         ProfileVisit[]
  profileVisitConfig    ProfileVisitConfig?
  recordDefinitions     RecordDefinition[]
  userRecords           UserRecord[]
  userStatSnapshots     UserStatSnapshot[]
  rewardDefinitions     RewardDefinition[]
  userRewards           UserReward[]
  activityFeedEvents    ActivityFeedEvent[]
  dailyCoachMessages    DailyCoachMessage[]
  coachMessageTemplates CoachMessageTemplate[]
  progressionEvents     ProgressionEvent[]
  reputationCriteria    ReputationCriterion[]
  userReputationScores  UserReputationScore[]
  userReputationIndexes UserReputationIndex[]
  userExperiences       UserExperience[]
  dashboardPreferences  DashboardPreference[]
  widgetConfigs         WidgetConfig[]
  levelDefinitions      LevelDefinition[]
  userLevelHistory      UserLevelHistory[]
  xpTransactions        XpTransaction[]


  @@index([slug])
  @@index([customDomain])
}

model BusinessUnit {
  id             String       @id @default(uuid())
  name           String
  code           String?
  description    String?
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  regions Region[]
  users   User[]

  @@index([organizationId])
}

model Region {
  id             String        @id @default(uuid())
  name           String
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessUnitId String?
  businessUnit   BusinessUnit? @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  sectors Sector[]
  users   User[]

  @@index([organizationId])
  @@index([businessUnitId])
}

model Sector {
  id        String   @id @default(uuid())
  name      String
  regionId  String
  region    Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites Site[]
  users User[]

  @@index([regionId])
}

model Site {
  id        String   @id @default(uuid())
  name      String
  address   String?
  city      String?
  sectorId  String
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@index([sectorId])
}

// ============================================================
// UTILISATEURS ET HIERARCHIE
// ============================================================

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  name           String?
  authId         String?       @unique
  role           UserRole      @default(SALES_REP)
  isActive       Boolean       @default(true)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  businessUnitId String?
  businessUnit   BusinessUnit? @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  regionId       String?
  region         Region?       @relation(fields: [regionId], references: [id], onDelete: SetNull)
  sectorId       String?
  sector         Sector?       @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  siteId         String?
  site           Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  managerId      String?
  manager        User?         @relation("UserHierarchy", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates   User[]        @relation("UserHierarchy")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  ownedProspects       Prospect[]             @relation("ProspectOwner")
  ownedProducts        Product[]              @relation("ProductOwner")
  ownedImportJobs      ImportJob[]            @relation("ImportJobOwner")
  auditEvents          AuditEvent[]
  kpiValues            UserKpiValue[]
  leaderboardEntries   LeaderboardEntry[]
  userBadges           UserBadge[]
  challengeParticipants ChallengeParticipant[]
  goals                Goal[]
  userLeagues          UserLeague[]
  userLeaguePeak       UserLeaguePeak?
  hallOfFameEntries    HallOfFameEntry[]
  publicProfile        UserPublicProfile?
  profileVisits        ProfileVisit[]        @relation("ProfileVisitVisitor")
  userRecords          UserRecord[]
  userStatSnapshots    UserStatSnapshot[]
  userRewards          UserReward[]
  activityFeedEvents   ActivityFeedEvent[]   @relation("ActivityFeedActor")
  dailyCoachMessages   DailyCoachMessage[]
  progressionEvents    ProgressionEvent[]
  reputationScores     UserReputationScore[]
  reputationIndex      UserReputationIndex?
  userExperience       UserExperience?
  dashboardPreference  DashboardPreference?
  xpTransactions       XpTransaction[]
  levelHistory         UserLevelHistory[]


  @@index([organizationId])
  @@index([businessUnitId])
  @@index([managerId])
  @@index([role])
  @@index([siteId])
}

// ============================================================
// DONNEES METIER
// ============================================================

model Prospect {
  id           String         @id @default(uuid())
  name         String
  company      String?
  email        String?
  value        Decimal        @default(0) @db.Decimal(12, 2)
  status       ProspectStatus @default(NEW)
  contactName  String?
  phone        String?
  mobile       String?
  website      String?
  address      String?
  postalCode   String?
  city         String?
  country      String?
  vatNumber    String?
  clientStatus ClientStatus   @default(PROSPECT)
  notes        String?
  ownerId      String
  owner        User           @relation("ProspectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([ownerId])
}

model Product {
  id                String   @id @default(uuid())
  name              String
  brand             String?
  supplier          String?
  supplierReference String?
  purchasePrice     Decimal  @default(0) @db.Decimal(12, 2)
  transportCost     Decimal  @default(0) @db.Decimal(12, 2)
  preparationCost   Decimal  @default(0) @db.Decimal(12, 2)
  accessoriesCost   Decimal  @default(0) @db.Decimal(12, 2)
  otherCosts        Decimal  @default(0) @db.Decimal(12, 2)
  costPrice         Decimal  @default(0) @db.Decimal(12, 2)
  sellingPrice      Decimal  @default(0) @db.Decimal(12, 2)
  marginAmount      Decimal  @default(0) @db.Decimal(12, 2)
  marginPercent     Decimal  @default(0) @db.Decimal(7, 2)
  ownerId           String
  owner             User     @relation("ProductOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([ownerId])
}

model ImportJob {
  id        String          @id @default(uuid())
  url       String
  status    ImportJobStatus @default(PENDING)
  ownerId   String?
  owner     User?           @relation("ImportJobOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([ownerId])
}
// ============================================================
// MODULE ENGINE (Ticket 016)
// ============================================================

model Module {
  id          String         @id @default(uuid())
  code        String         @unique
  name        String
  description String?
  category    ModuleCategory
  icon        String?
  isCore      Boolean        @default(false)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  organizations OrganizationModule[]

  @@index([code])
  @@index([category])
}

model Feature {
  id          String      @id @default(uuid())
  code        FeatureCode @unique
  name        String
  description String?
  isActive    Boolean     @default(true)
  isBeta      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  organizations OrganizationFeature[]

  @@index([code])
}

model OrganizationModule {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  moduleId       String
  module         Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  isEnabled      Boolean      @default(true)
  enabledAt      DateTime     @default(now())
  expiresAt      DateTime?
  config         Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, moduleId])
  @@index([organizationId])
  @@index([moduleId])
}

model OrganizationFeature {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  featureId      String
  feature        Feature      @relation(fields: [featureId], references: [id], onDelete: Cascade)
  isEnabled      Boolean      @default(true)
  enabledAt      DateTime     @default(now())
  expiresAt      DateTime?
  quota          Int?
  usageCount     Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, featureId])
  @@index([organizationId])
  @@index([featureId])
}

// ============================================================
// AUDIT ENGINE (Ticket 018)
// ============================================================

model AuditEvent {
  id             String          @id @default(uuid())
  eventId        String          @unique
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessUnitId String?
  userId         String?
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  resourceType   String
  resourceId     String
  event          DomainEventType
  occurredAt     DateTime
  ipAddress      String?
  userAgent      String?
  device         String?
  browser        String?
  country        String?
  city           String?
  metadata       Json            @default("{}")
  before         Json?
  after          Json?
  isSystemEvent  Boolean         @default(false)
  createdAt      DateTime        @default(now())

  @@index([organizationId])
  @@index([organizationId, occurredAt])
  @@index([organizationId, event])
  @@index([organizationId, resourceType, resourceId])
  @@index([userId])
  @@index([userId, occurredAt])
  @@index([resourceType, resourceId])
  @@index([event])
  @@index([occurredAt])
  @@index([businessUnitId])
  @@index([isSystemEvent])
  @@map("audit_events")
}

// ============================================================
// TENANT CONFIGURATION ENGINE (Ticket 019)
// ============================================================

model OrganizationSetting {
  id             String           @id @default(uuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  key            String
  value          String
  valueType      SettingValueType @default(STRING)
  category       SettingCategory  @default(GENERAL)
  description    String?
  defaultValue   String?
  isReadOnly     Boolean          @default(false)
  isVisible      Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
  @@index([organizationId, category])
  @@map("organization_settings")
}

model WorkflowTemplate {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String
  name           String
  description    String?
  entityType     String
  isDefault      Boolean      @default(false)
  isActive       Boolean      @default(true)
  color          String?      @default("#3B82F6")
  icon           String?
  displayOrder   Int          @default(0)
  config         Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  steps WorkflowStep[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, entityType])
  @@index([organizationId, isDefault])
  @@map("workflow_templates")
}

model WorkflowStep {
  id                 String           @id @default(uuid())
  workflowTemplateId String
  workflowTemplate   WorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)
  code               String
  name               String
  description        String?
  order              Int              @default(0)
  color              String?          @default("#6B7280")
  icon               String?
  isInitial          Boolean          @default(false)
  isFinal            Boolean          @default(false)
  isSuccess          Boolean          @default(false)
  transitions        Json             @default("[]")
  entryConditions    Json?
  onEnterActions     Json?
  slaHours           Int?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([workflowTemplateId, code])
  @@index([workflowTemplateId])
  @@index([workflowTemplateId, order])
  @@map("workflow_steps")
}

model NotificationTemplate {
  id             String              @id @default(uuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel        NotificationChannel
  eventType      String
  name           String
  subject        String?
  body           String
  bodyHtml       String?
  locale         String              @default("fr")
  isActive       Boolean             @default(true)
  isDefault      Boolean             @default(false)
  availableVars  Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([organizationId, channel, eventType, locale])
  @@index([organizationId])
  @@index([organizationId, channel])
  @@index([organizationId, eventType])
  @@map("notification_templates")
}

model Integration {
  id          String              @id @default(uuid())
  provider    IntegrationProvider @unique
  name        String
  description String?
  icon        String?
  website     String?
  docsUrl     String?
  configSchema Json?
  apiVersion  String?
  isActive    Boolean             @default(true)
  isBeta      Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  organizations OrganizationIntegration[]

  @@index([provider])
}

model OrganizationIntegration {
  id               String            @id @default(uuid())
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integrationId    String
  integration      Integration       @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  status           IntegrationStatus @default(PENDING_SETUP)
  config           Json?
  encryptedConfig  String?
  expiresAt        DateTime?
  lastUsedAt       DateTime?
  lastErrorAt      DateTime?
  lastErrorMsg     String?
  monthlyCallCount Int               @default(0)
  monthlyQuota     Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([organizationId, integrationId])
  @@index([organizationId])
  @@index([integrationId])
  @@index([status])
  @@map("organization_integrations")
}
// ============================================================
// PERFORMANCE ENGINE (Ticket 020)
// ============================================================

model KpiDefinition {
  id              String             @id @default(uuid())
  organizationId  String
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code            String
  name            String
  description     String?
  unit            KpiUnit            @default(COUNT)
  calculationType KpiCalculationType @default(SUM)
  aggregation     KpiAggregation     @default(MONTHLY)
  icon            String?
  color           String?            @default("#3B82F6")
  displayOrder    Int                @default(0)
  config          Json?
  defaultTarget   Decimal?           @db.Decimal(15, 4)
  alertThreshold  Decimal?           @db.Decimal(15, 4)
  isActive        Boolean            @default(true)
  isPublic        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  values       UserKpiValue[]
  leaderboards Leaderboard[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("kpi_definitions")
}

model UserKpiValue {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kpiId          String
  kpi            KpiDefinition @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  value          Decimal       @db.Decimal(15, 4)
  periodStart    DateTime
  periodEnd      DateTime
  calculatedAt   DateTime      @default(now())
  source         String        @default("event_bus")
  metadata       Json          @default("{}")
  seasonId       String?
  season         Season?       @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([kpiId])
  @@index([organizationId])
  @@index([userId, kpiId])
  @@index([userId, periodStart, periodEnd])
  @@index([organizationId, kpiId, periodStart])
  @@index([seasonId])
  @@map("user_kpi_values")
}

model Leaderboard {
  id             String           @id @default(uuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  kpiId          String
  kpi            KpiDefinition    @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  scope          LeaderboardScope @default(ORGANIZATION)
  type           LeaderboardType  @default(RANKING)
  scopeEntityId  String?
  aggregation    KpiAggregation   @default(MONTHLY)
  isPublic       Boolean          @default(true)
  isActive       Boolean          @default(true)
  maxEntries     Int              @default(10)
  config         Json?
  seasonId       String?
  season         Season?          @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  entries LeaderboardEntry[]

  @@index([organizationId])
  @@index([organizationId, scope])

  expiresAt      DateTime?
  quota          Int?
  usageCount     Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, featureId])
  @@index([organizationId])
  @@index([featureId])
}


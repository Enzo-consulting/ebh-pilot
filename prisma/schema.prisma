generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  CEO
  REGIONAL_DIRECTOR
  SECTOR_DIRECTOR
  SITE_DIRECTOR
  SALES_MANAGER
  SALES_REP
}

/// Theme par defaut de l interface pour cette organisation.
enum Theme {
  LIGHT
  DARK
  AUTO
}

enum ProspectStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  INACTIVE
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

// ============================================================
// MODULE ENGINE — Ticket 016
// ============================================================

/// Categorie fonctionnelle d un module.
enum ModuleCategory {
  SALES
  OPERATIONS
  FINANCE
  HR
  ANALYTICS
  AI
  INTEGRATION
  COMMUNICATION
  DOCUMENTS
  MOBILE
}

/// Code unique d une fonctionnalite activable par organisation.
enum FeatureCode {
  AI_TRANSLATION
  AI_ANALYSIS
  AI_IMPORT
  AI_ASSISTANT
  PDF_GENERATION
  EXPORT_EXCEL
  EXPORT_PDF
  DOCUMENTS
  EMAILING
  SMS
  WHATSAPP
  PUSH_NOTIFICATIONS
  YOUSIGN
  DOCUSIGN
  API_ACCESS
  WEBHOOK
  REPORTING
  ADVANCED_ANALYTICS
  CUSTOM_DASHBOARDS
  MOBILE_APP
  GPS_TRACKING
  QR_SCAN
  BARCODE_SCAN
  OFFLINE_MODE
  CUSTOM_DOMAIN
  WHITE_LABEL
  CHALLENGES
  LEADERBOARD
  AUDIT_LOG
  MULTI_ORGANIZATION
  SSO
}

// ============================================================
// ORGANISATION MULTI-TENANT — WHITE LABEL
// ============================================================

model Organization {
  id               String  @id @default(uuid())
  name             String
  displayName      String?
  slug             String  @unique
  tagline          String?
  logoUrl          String?
  logoCompactUrl   String?
  faviconUrl       String?
  loginImageUrl    String?
  primaryColor     String? @default("#3B82F6")
  secondaryColor   String? @default("#1E40AF")
  accentColor      String? @default("#F59E0B")
  defaultTheme     Theme   @default(LIGHT)
  website          String?
  supportEmail     String?
  supportPhone     String?
  customDomain     String? @unique
  language         String  @default("fr")
  timezone         String  @default("Europe/Paris")
  currency         String  @default("EUR")
  dateFormat       String  @default("DD/MM/YYYY")
  numberFormat     String  @default(",")
  privacyPolicyUrl String?
  termsUrl         String?
  footerLink       String?
  footerText       String?
  isWhiteLabelEnabled Boolean @default(false)
  isActive         Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  businessUnits BusinessUnit[]
  regions       Region[]
  users         User[]
  modules       OrganizationModule[]
  features      OrganizationFeature[]

  @@index([slug])
  @@index([customDomain])
}

model BusinessUnit {
  id             String       @id @default(uuid())
  name           String
  code           String?
  description    String?
  isActive       Boolean      @default(true)
  organizationId String
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


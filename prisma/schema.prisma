// ============================================================

/// Événement de progression déclenché par le moteur d'engagement
model ProgressionEvent {
  id             String                @id @default(uuid())
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           ProgressionEventType
  previousValue  String?
  newValue       String?
  metadata       Json                  @default("{}")
  notified       Boolean               @default(false)
  notifiedAt     DateTime?
  occurredAt     DateTime              @default(now())
  createdAt      DateTime              @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([userId, type])
  @@index([organizationId, occurredAt])
  @@index([notified])
  @@map("progression_events")
}

// ============================================================
// REPUTATION ENGINE
// ============================================================

/// Définition d'un critère de réputation (générique)
model ReputationCriterion {
  id             String                  @id @default(uuid())
  organizationId String
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String
  name           String
  description    String?
  type           ReputationCriterionType
  weight         Decimal                 @default(1.0) @db.Decimal(5, 2)
  maxScore       Decimal                 @default(100) @db.Decimal(7, 2)
  config         Json                    @default("{}")
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  reputationScores UserReputationScore[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("reputation_criteria")
}

/// Score de réputation d'un utilisateur par critère
model UserReputationScore {
  id                   String              @id @default(uuid())
  userId               String
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId       String
  organization         Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  criterionId          String
  criterion            ReputationCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  score                Decimal             @db.Decimal(7, 2)
  maxScore             Decimal             @db.Decimal(7, 2)
  normalizedScore      Decimal             @db.Decimal(5, 2)
  computedAt           DateTime            @default(now())
  metadata             Json                @default("{}")

  @@index([userId])
  @@index([organizationId])
  @@index([criterionId])
  @@index([userId, criterionId, computedAt])
  @@map("user_reputation_scores")
}

/// Index de réputation global d'un utilisateur (score agrégé)
model UserReputationIndex {
  id                  String       @id @default(uuid())
  userId              String       @unique
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  globalScore         Decimal      @db.Decimal(7, 2)
  percentile          Decimal?     @db.Decimal(5, 2)
  rankInOrganization  Int?
  breakdown           Json         @default("{}")
  computedAt          DateTime     @default(now())
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, globalScore])
  @@map("user_reputation_indexes")
}

// ============================================================
// PROGRESSION ENGINE (Ticket 021C)
// ============================================================

/// Expérience et niveau courant d'un utilisateur (un enregistrement par user)
model UserExperience {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// XP cumulé dans la saison / période courante
  totalXp         Int          @default(0)
  /// Niveau actuel calculé (1-based)
  currentLevel    Int          @default(1)
  /// XP acquis depuis le début du niveau courant
  currentLevelXp  Int          @default(0)
  /// XP requis pour atteindre le niveau suivant (snapshot pour perf)
  nextLevelXp     Int          @default(100)
  /// XP cumulé sur toute la vie du compte (jamais réinitialisé)
  lifetimeXp      Int          @default(0)
  updatedAt       DateTime     @updatedAt
  createdAt       DateTime     @default(now())

  xpTransactions   XpTransaction[]
  levelHistory     UserLevelHistory[]

  @@index([organizationId])
  @@index([organizationId, totalXp])
  @@index([organizationId, currentLevel])
  @@map("user_experiences")
}

/// Définition d'un niveau (personnalisable par organisation, sinon système)
model LevelDefinition {
  id             String        @id @default(uuid())
  /// Null = niveau système (partagé par toutes les orgs sans personnalisation)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Numéro de niveau (1, 2, 3, ...)
  level          Int
  /// Libellé affiché (ex. "Recrue", "Expert", "Légende")
  title          String
  /// XP minimum pour atteindre ce niveau
  minXp          Int
  /// Icône (emoji, nom d'icône ou URL)
  icon           String?
  /// Couleur HEX
  color          String?       @default("#6366F1")
  /// Récompenses JSON déclenchées à l'atteinte du niveau
  rewardJson     Json          @default("{}")
  /// True si ce niveau fait partie du référentiel système par défaut
  isDefault      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, level])
  @@index([organizationId])
  @@index([organizationId, minXp])
  @@index([isDefault])
  @@map("level_definitions")
}

/// Historique des montées de niveau (jamais supprimé)
model UserLevelHistory {
  id               String          @id @default(uuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userExperienceId String
  userExperience   UserExperience  @relation(fields: [userExperienceId], references: [id], onDelete: Cascade)
  oldLevel         Int
  newLevel         Int
  xpAtPromotion    Int
  promotedAt       DateTime        @default(now())
  metadata         Json            @default("{}")

  @@index([userId])
  @@index([organizationId])
  @@index([userId, promotedAt])
  @@index([organizationId, newLevel])
  @@map("user_level_history")
}

/// Historique complet de tous les gains et pertes de XP
model XpTransaction {
  id               String          @id @default(uuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userExperienceId String
  userExperience   UserExperience  @relation(fields: [userExperienceId], references: [id], onDelete: Cascade)
  /// Type d'événement source du gain/perte
  sourceEvent      XpSourceEvent
  /// Type de ressource ayant déclenché le gain (ex. "Badge", "Goal", "Challenge")
  sourceResource   String?
  /// ID de la ressource source (pour audit)
  sourceResourceId String?
  /// Montant de XP (positif = gain, négatif = retrait)
  xp               Int
  /// XP total de l'utilisateur après cette transaction
  balanceAfter     Int
  /// Motif lisible par un humain
  reason           String?
  /// Données contextuelles libres
  metadata         Json            @default("{}")
  seasonId         String?
  season           Season?         @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([userId, createdAt])
  @@index([organizationId, sourceEvent])
  @@index([seasonId])
  @@map("xp_transactions")
}

// ============================================================
// DASHBOARD ENGINE (Ticket 021D)
// ============================================================

/// Préférences de dashboard d'un utilisateur (layout, widgets actifs)
model DashboardPreference {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dashboardType  DashboardType @default(SALES_REP)
  /// Ordre et visibilité des widgets [{ widgetType, position, isVisible }]
  widgetLayout   Json          @default("[]")
  /// Personnalisation de la branding pour ce profil (override org)
  brandingOverride Json        @default("{}")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@map("dashboard_preferences")
}

/// Configuration d'un widget par organisation (couleurs, seuils, labels)
model WidgetConfig {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  widgetType     WidgetType
  /// Libellé personnalisé (ex. "Mon score du jour" vs "Today's score")
  label          String?
  /// Icône personnalisée
  icon           String?
  /// Couleur de la carte widget (hex)
  color          String?      @default("#6366F1")
  /// Configuration spécifique au widget (seuils, nombre d'entrées, etc.)
  config         Json         @default("{}")
  isEnabled      Boolean      @default(true)
  displayOrder   Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, widgetType])
  @@index([organizationId])
  @@index([organizationId, isEnabled])
  @@map("widget_configs")
}

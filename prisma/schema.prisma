generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  CEO
  REGIONAL_DIRECTOR
  SECTOR_DIRECTOR
  SITE_DIRECTOR
  SALES_MANAGER
  SALES_REP
}

/// Theme par defaut de l interface pour cette organisation.
enum Theme {
  LIGHT
  DARK
  AUTO
}

enum ProspectStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  INACTIVE
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

// ============================================================
// MODULE ENGINE — Ticket 016
// ============================================================

/// Categorie fonctionnelle d un module.
enum ModuleCategory {
  SALES
  OPERATIONS
  FINANCE
  HR
  ANALYTICS
  AI
  INTEGRATION
  COMMUNICATION
  DOCUMENTS
  MOBILE
}

/// Code unique d une fonctionnalite activable par organisation.
enum FeatureCode {
  AI_TRANSLATION
  AI_ANALYSIS
  AI_IMPORT
  AI_ASSISTANT
  PDF_GENERATION
  EXPORT_EXCEL
  EXPORT_PDF
  DOCUMENTS
  EMAILING
  SMS
  WHATSAPP
  PUSH_NOTIFICATIONS
  YOUSIGN
  DOCUSIGN
  API_ACCESS
  WEBHOOK
  REPORTING
  ADVANCED_ANALYTICS
  CUSTOM_DASHBOARDS
  MOBILE_APP
  GPS_TRACKING
  QR_SCAN
  BARCODE_SCAN
  OFFLINE_MODE
  CUSTOM_DOMAIN
  WHITE_LABEL
  CHALLENGES
  LEADERBOARD
  AUDIT_LOG
  MULTI_ORGANIZATION
  SSO
}

// ============================================================
// ORGANISATION MULTI-TENANT — WHITE LABEL
// ============================================================

model Organization {
  id               String  @id @default(uuid())
  name             String
  displayName      String?
  slug             String  @unique
  tagline          String?
  logoUrl          String?
  logoCompactUrl   String?
  faviconUrl       String?
  loginImageUrl    String?
  primaryColor     String? @default("#3B82F6")
  secondaryColor   String? @default("#1E40AF")
  accentColor      String? @default("#F59E0B")
  defaultTheme     Theme   @default(LIGHT)
  website          String?
  supportEmail     String?
  supportPhone     String?
  customDomain     String? @unique
  language         String  @default("fr")
  timezone         String  @default("Europe/Paris")
  currency         String  @default("EUR")
  dateFormat       String  @default("DD/MM/YYYY")
  numberFormat     String  @default(",")
  privacyPolicyUrl String?
  termsUrl         String?
  footerLink       String?
  footerText       String?
  isWhiteLabelEnabled Boolean @default(false)
  isActive         Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  businessUnits BusinessUnit[]
  regions       Region[]
  users         User[]
  modules       OrganizationModule[]
  features      OrganizationFeature[]

  @@index([slug])
  @@index([customDomain])
}

model BusinessUnit {
  id             String       @id @default(uuid())
  name           String
  code           String?
  description    String?
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  regions        Region[]
  users          User[]

  @@index([organizationId])
}

model Region {
  id             String        @id @default(uuid())
  name           String
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessUnitId String?
  businessUnit   BusinessUnit? @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  sectors        Sector[]
  users          User[]

  @@index([organizationId])
  @@index([businessUnitId])
}

model Sector {
  id        String   @id @default(uuid())
  name      String
  regionId  String
  region    Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sites     Site[]
  users     User[]

  @@index([regionId])
}

model Site {
  id        String   @id @default(uuid())
  name      String
  address   String?
  city      String?
  sectorId  String
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  @@index([sectorId])
}

// ============================================================
// UTILISATEURS ET HIERARCHIE
// ============================================================

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  name           String?
  authId         String?       @unique
  role           UserRole      @default(SALES_REP)
  isActive       Boolean       @default(true)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  businessUnitId String?
  businessUnit   BusinessUnit? @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  regionId       String?
  region         Region?       @relation(fields: [regionId], references: [id], onDelete: SetNull)
  sectorId       String?
  sector         Sector?       @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  siteId         String?
  site           Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  managerId      String?
  manager        User?         @relation("UserHierarchy", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates   User[]        @relation("UserHierarchy")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  ownedProspects  Prospect[]   @relation("ProspectOwner")
  ownedProducts   Product[]    @relation("ProductOwner")
  ownedImportJobs ImportJob[]  @relation("ImportJobOwner")

  @@index([organizationId])
  @@index([businessUnitId])
  @@index([managerId])
  @@index([role])
  @@index([siteId])
}

// ============================================================
// DONNEES METIER
// ============================================================

model Prospect {
  id          String         @id @default(uuid())
  name        String
  company     String?
  email       String?
  value       Decimal        @default(0) @db.Decimal(12, 2)
  status      ProspectStatus @default(NEW)
  contactName String?
  phone       String?
  mobile      String?
  website     String?
  address     String?
  postalCode  String?
  city        String?
  country     String?
  vatNumber   String?
  clientStatus ClientStatus  @default(PROSPECT)
  notes       String?
  ownerId     String
  owner       User           @relation("ProspectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([ownerId])
}

model Product {
  id                 String   @id @default(uuid())
  name               String
  brand              String?
  supplier           String?
  supplierReference  String?
  purchasePrice      Decimal  @default(0) @db.Decimal(12, 2)
  transportCost      Decimal  @default(0) @db.Decimal(12, 2)
  preparationCost    Decimal  @default(0) @db.Decimal(12, 2)
  accessoriesCost    Decimal  @default(0) @db.Decimal(12, 2)
  otherCosts         Decimal  @default(0) @db.Decimal(12, 2)
  costPrice          Decimal  @default(0) @db.Decimal(12, 2)
  sellingPrice       Decimal  @default(0) @db.Decimal(12, 2)
  marginAmount       Decimal  @default(0) @db.Decimal(12, 2)
  marginPercent      Decimal  @default(0) @db.Decimal(7, 2)
  ownerId            String
  owner              User     @relation("ProductOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([ownerId])
}

model ImportJob {
  id        String          @id @default(uuid())
  url       String
  status    ImportJobStatus @default(PENDING)
  ownerId   String?
  owner     User?           @relation("ImportJobOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([ownerId])
}

// ============================================================
// MODULE ENGINE — Ticket 016
// ============================================================

/// Module fonctionnel de la plateforme EBH Pilot.
/// Exemples : CRM, Produits, Clients, Stocks, RH, Documents, BI, IA
model Module {
  id          String         @id @default(uuid())
  code        String         @unique
  name        String
  description String?
  category    ModuleCategory
  icon        String?
  isCore      Boolean        @default(false)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  organizations OrganizationModule[]

  @@index([code])
  @@index([category])
}

/// Fonctionnalite technique activable independamment d un module.
/// Exemples : AI_TRANSLATION, PDF_GENERATION, MOBILE_APP, YOUSIGN
model Feature {
  id          String      @id @default(uuid())
  code        FeatureCode @unique
  name        String
  description String?
  isActive    Boolean     @default(true)
  isBeta      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  organizations OrganizationFeature[]

  @@index([code])
}

/// Table de liaison : modules actives pour une organisation.
model OrganizationModule {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  moduleId       String
  module         Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  isEnabled      Boolean      @default(true)
  enabledAt      DateTime     @default(now())
  expiresAt      DateTime?
  config         Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, moduleId])
  @@index([organizationId])
  @@index([moduleId])
}

/// Table de liaison : fonctionnalites actives pour une organisation.
model OrganizationFeature {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  featureId      String
  feature        Feature      @relation(fields: [featureId], references: [id], onDelete: Cascade)
  isEnabled      Boolean      @default(true)
  enabledAt      DateTime     @default(now())
  expiresAt      DateTime?
  quota          Int?
  usageCount     Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, featureId])
  @@index([organizationId])
  @@index([featureId])
}

// ============================================================
// LEAGUE ENGINE
// ============================================================

/// Définition des ligues disponibles dans une organisation
model LeagueDefinition {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tier           LeagueTier
  name           String
  description    String?
  icon           String?
  color          String?      @default("#CD7F32")
  minScore       Decimal?     @db.Decimal(15, 4)
  maxScore       Decimal?     @db.Decimal(15, 4)
  minRankPercent Decimal?     @db.Decimal(5, 2)
  maxRankPercent Decimal?     @db.Decimal(5, 2)
  xpBonus        Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  userLeagues UserLeague[]

  @@unique([organizationId, tier])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("league_definitions")
}

/// Ligue courante et historique d'un utilisateur
model UserLeague {
  id                 String            @id @default(uuid())
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId     String
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  seasonId           String?
  season             Season?           @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  leagueDefinitionId String
  leagueDefinition   LeagueDefinition  @relation(fields: [leagueDefinitionId], references: [id], onDelete: Cascade)
  tier               LeagueTier
  assignedAt         DateTime          @default(now())
  isCurrent          Boolean           @default(true)
  promotedFrom       LeagueTier?
  demotedFrom        LeagueTier?
  scoreAtAssignment  Decimal?          @db.Decimal(15, 4)
  rankAtAssignment   Int?
  metadata           Json              @default("{}")
  createdAt          DateTime          @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([userId, isCurrent])
  @@index([organizationId, tier])
  @@index([seasonId])
  @@map("user_leagues")
}

/// Meilleure ligue atteinte par un utilisateur (jamais réinitialisée)
model UserLeaguePeak {
  id             String     @id @default(uuid())
  userId         String     @unique
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  peakTier       LeagueTier
  achievedAt     DateTime
  seasonId       String?
  season         Season?    @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([organizationId])
  @@index([organizationId, peakTier])
  @@map("user_league_peaks")
}

// ============================================================
// HALL OF FAME
// ============================================================

/// Entrée permanente au Hall of Fame — jamais supprimée
model HallOfFameEntry {
  id             String              @id @default(uuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       HallOfFameCategory
  scope          RecordScope
  scopeRefId     String?
  userId         String?
  user           User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName       String
  userAvatarUrl  String?
  kpiDefinitionId String?
  kpiCode        String?
  kpiName        String?
  value          Decimal             @db.Decimal(15, 4)
  unit           String?
  seasonId       String?
  season         Season?             @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  seasonName     String?
  year           Int?
  rank           Int                 @default(1)
  achievedAt     DateTime
  metadata       Json                @default("{}")
  createdAt      DateTime            @default(now())

  @@index([organizationId])
  @@index([organizationId, category])
  @@index([organizationId, scope, scopeRefId])
  @@index([userId])
  @@index([year])
  @@index([seasonId])
  @@map("hall_of_fame_entries")
}


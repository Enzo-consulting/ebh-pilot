  regions       Region[]
  users         User[]
  modules       OrganizationModule[]
  features      OrganizationFeature[]

  @@index([slug])
  @@index([customDomain])
}

model BusinessUnit {
  id             String       @id @default(uuid())
  name           String
  code           String?
  description    String?
  isActive       Boolean      @default(true)
  organizationId String
  provider = "prisma-client-js"
}


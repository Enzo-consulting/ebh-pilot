model AuditEvent {
  id             String          @id @default(uuid())
  eventId        String          @unique
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessUnitId String?
  userId         String?
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  resourceType   String
  resourceId     String
  event          DomainEventType
  occurredAt     DateTime
  ipAddress      String?
  userAgent      String?
  device         String?
  browser        String?
  country        String?
  city           String?
  metadata       Json            @default("{}")
  before         Json?
  after          Json?
  isSystemEvent  Boolean         @default(false)
  createdAt      DateTime        @default(now())

  @@index([organizationId])
  @@index([organizationId, occurredAt])
  @@index([organizationId, event])
  @@index([organizationId, resourceType, resourceId])
  @@index([userId])
  @@index([userId, occurredAt])
  @@index([resourceType, resourceId])
  @@index([event])
  @@index([occurredAt])
  @@index([businessUnitId])
  @@index([isSystemEvent])
  @@map("audit_events")
}
// ============================================================
// TENANT CONFIGURATION ENGINE — Ticket 019
// ============================================================

/// Parametre de configuration specifique a une organisation.
///
/// Ce modele est le coeur du Tenant Configuration Engine.
/// Il stocke toutes les configurations propres a chaque organisation,
/// organisees par categorie et identifiees par une cle unique.
///
/// EXEMPLES DE CLES :
///   language, timezone, currency, fiscalYear, vatRate
///   quotationPrefix, invoicePrefix, dateFormat, timeFormat
///   decimalSeparator, thousandSeparator, maxProspectsPerUser
///   defaultWorkflow, aiProvider, aiModel, aiTemperature
///   primaryColor, fontFamily, logoHeight
///
/// REGLES :
/// - Une cle est unique par organisation (contrainte @@unique)
/// - La valeur est toujours une string serialisee
/// - Le type est stocke pour la deserialisation cote application
/// - Les valeurs sensibles (API keys) ne sont jamais stockees ici
///   — utiliser OrganizationIntegration.encryptedConfig a la place
model OrganizationSetting {
  id             String           @id @default(uuid())

  /// Organisation proprietaire de ce parametre
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Cle unique du parametre au sein de l organisation
  /// Convention: snake_case (ex: "vat_rate", "fiscal_year_start", "ai_model")
  key            String

  /// Valeur serialisee en string
  /// Numbers: "19.6", Booleans: "true"/"false", JSON: "{...}", Colors: "#3B82F6"
  value          String

  /// Type de la valeur pour la deserialisation
  valueType      SettingValueType @default(STRING)

  /// Categorie pour le regroupement et les permissions
  category       SettingCategory  @default(GENERAL)

  /// Description lisible par un humain (pour l interface admin)
  description    String?

  /// Valeur par defaut du systeme (pour le reset)
  defaultValue   String?

  /// Si true, cette valeur ne peut pas etre modifiee par l admin de l organisation
  /// (reserve aux super-admins EBH-Pilot)
  isReadOnly     Boolean          @default(false)

  /// Si true, ce parametre est visible dans l interface admin de l organisation
  isVisible      Boolean          @default(true)

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
  @@index([organizationId, category])
  @@map("organization_settings")
}

/// Template de workflow personnalisable par organisation.
///
/// Un workflow definit les etapes par lesquelles passe une entite metier.
/// Exemples : Prospect, Client, Commande, SAV, Projet, Maintenance, RH
///
/// Chaque organisation peut avoir ses propres workflows independamment des autres.
/// Un secteur peut avoir un workflow "Prospect" different d un autre secteur.
///
/// EXEMPLES :
///   - Automobile : Prospect → Contact → Essai → Offre → Commande → Livraison
///   - Remorque : Prospect → Devis → Commande → Production → Livraison
///   - Immobilier : Prospect → Visite → Offre → Compromis → Acte
///   - Assurance : Prospect → Analyse → Devis → Signature → Suivi
model WorkflowTemplate {
  id             String       @id @default(uuid())

  /// Organisation proprietaire de ce workflow
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Nom technique du workflow (ex: "prospect", "client", "order", "sav")
  code           String

  /// Nom affiche a l utilisateur
  name           String

  /// Description du workflow
  description    String?

  /// Type d entite auquel s applique ce workflow
  /// Exemples : "prospect", "client", "order", "ticket", "project", "employee"
  entityType     String

  /// Si true, ce workflow est utilise par defaut pour ce type d entite
  isDefault      Boolean      @default(false)

  /// Si false, ce workflow est archive et n est plus utilise
  isActive       Boolean      @default(true)

  /// Couleur de la carte workflow dans l interface
  color          String?      @default("#3B82F6")

  /// Icone du workflow (nom d icone Lucide ou URL)
  icon           String?

  /// Ordre d affichage dans la liste des workflows
  displayOrder   Int          @default(0)

  /// Configuration JSON libre pour les extensions futures
  config         Json?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  steps WorkflowStep[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, entityType])
  @@index([organizationId, isDefault])
  @@map("workflow_templates")
}

/// Etape d un workflow configurable.
///
/// Chaque etape represente un statut ou une phase du workflow.
/// Les transitions definissent vers quelles etapes on peut avancer ou reculer.
///
/// EXEMPLES pour un workflow Prospect :
///   Step 1: "Nouveau"     → transitions: [2]
///   Step 2: "Contacte"    → transitions: [3, 5]
///   Step 3: "Qualifie"    → transitions: [4, 5]
///   Step 4: "Gagne"       → transitions: []
///   Step 5: "Perdu"       → transitions: []
model WorkflowStep {
  id                 String           @id @default(uuid())

  workflowTemplateId String
  workflowTemplate   WorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Cascade)

  /// Code technique de l etape (ex: "new", "contacted", "won", "lost")
  code               String

  /// Nom affiche a l utilisateur
  name               String

  /// Description de cette etape
  description        String?

  /// Position dans le workflow (0 = premiere etape)
  order              Int              @default(0)

  /// Couleur de l etape (badge, kanban card)
  color              String?          @default("#6B7280")

  /// Icone de l etape (nom Lucide ou URL)
  icon               String?

  /// Si true, c est l etape initiale (entree dans le workflow)
  isInitial          Boolean          @default(false)

  /// Si true, c est une etape terminale (sortie du workflow)
  isFinal            Boolean          @default(false)

  /// Si true, cette etape est consideree comme un succes (ex: "Gagne", "Livre")
  isSuccess          Boolean          @default(false)

  /// Codes des etapes vers lesquelles on peut transitionner depuis cette etape
  /// Stocke comme tableau JSON: ["contacted", "lost"]
  transitions        Json             @default("[]")

  /// Conditions requises pour entrer dans cette etape (JSON)
  /// Exemples: { "requiredFields": ["email", "phone"], "minScore": 50 }
  entryConditions    Json?

  /// Actions automatiques declenchees lors de l entree dans cette etape (JSON)
  /// Exemples: { "notify": ["manager"], "createTask": "call_back", "emit": "PROSPECT_UPDATED" }
  onEnterActions     Json?

  /// Delai SLA avant escalade (en heures). Null = pas de SLA.
  slaHours           Int?

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([workflowTemplateId, code])
  @@index([workflowTemplateId])
  @@index([workflowTemplateId, order])
  @@map("workflow_steps")
}

/// Template de notification par canal et par evenement.
///
/// Permet a chaque organisation de personnaliser les messages envoyes
/// selon le canal (email, SMS, push, WhatsApp, Teams, Slack, Discord).
///
/// VARIABLES SUPPORTEES dans les templates (handlebars-like) :
///   {{user.name}}, {{organization.name}}, {{resource.name}},
///   {{event}}, {{date}}, {{url}}, {{branding.primaryColor}}
///
/// EXEMPLES :
///   Canal: EMAIL, Evenement: PROSPECT_CREATED
///   Sujet: "Nouveau prospect : {{prospect.name}}"
///   Corps: "Bonjour {{user.name}}, un nouveau prospect a ete cree..."
model NotificationTemplate {
  id             String              @id @default(uuid())

  /// Organisation proprietaire de ce template
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Canal de notification
  channel        NotificationChannel

  /// Evenement de domaine qui declenche ce template
  /// Correspond aux valeurs de DomainEventType (Ticket 017)
  eventType      String

  /// Nom affiche dans l interface admin
  name           String

  /// Sujet du message (pour email, push, Teams)
  subject        String?

  /// Corps du message (texte ou HTML selon le canal)
  body           String

  /// Version HTML du corps (pour email uniquement)
  bodyHtml       String?

  /// Langue de ce template (code ISO 639-1, ex: "fr", "en", "de")
  locale         String              @default("fr")

  /// Si false, ce template est desactive (les notifications ne sont pas envoyees)
  isActive       Boolean             @default(true)

  /// Si true, ce template est le template par defaut pour ce canal + evenement + locale
  isDefault      Boolean             @default(false)

  /// Variables disponibles pour ce template (documentation)
  availableVars  Json?

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([organizationId, channel, eventType, locale])
  @@index([organizationId])
  @@index([organizationId, channel])
  @@index([organizationId, eventType])
  @@map("notification_templates")
}

/// Definition d une integration externe disponible sur la plateforme.
///
/// Ce modele decrit ce qu est une integration (comme un catalogue).
/// L activation par organisation est geree dans OrganizationIntegration.
///
/// EXEMPLES :
///   OpenAI, Anthropic, Stripe, Pennylane, YouSign, Google Workspace
model Integration {
  id          String              @id @default(uuid())

  /// Fournisseur de l integration
  provider    IntegrationProvider @unique

  /// Nom affiche
  name        String

  /// Description de l integration
  description String?

  /// Icone (URL ou nom)
  icon        String?

  /// Site officiel
  website     String?

  /// Documentation de l integration
  docsUrl     String?

  /// Champs de configuration requis (JSON schema)
  /// Exemples: { "apiKey": { "type": "string", "required": true, "secret": true } }
  configSchema Json?

  /// Version de l API supportee
  apiVersion  String?

  /// Si false, cette integration n est plus disponible
  isActive    Boolean             @default(true)

  /// Si true, cette integration est en beta
  isBeta      Boolean             @default(false)

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  organizations OrganizationIntegration[]

  @@index([provider])
}

/// Activation et configuration d une integration pour une organisation specifique.
///
/// SECURITE — API KEYS :
/// Les cles API ne sont JAMAIS stockees en clair dans la base de donnees.
/// Le champ encryptedConfig stocke les valeurs sensibles chiffrees (AES-256-GCM).
/// La cle de chiffrement est une variable d environnement (ENCRYPTION_KEY).
///
/// Le champ config peut stocker des valeurs non-sensibles (endpoint URL, model name, etc.)
model OrganizationIntegration {
  id             String            @id @default(uuid())

  /// Organisation qui utilise cette integration
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Integration activee
  integrationId  String
  integration    Integration       @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  /// Statut de l integration
  status         IntegrationStatus @default(PENDING_SETUP)

  /// Configuration non-sensible (endpoint, model, options)
  config         Json?

  /// Configuration chiffree (API keys, secrets, tokens)
  /// JAMAIS stocke en clair. Chiffrement AES-256-GCM.
  encryptedConfig String?

  /// Date d expiration de l integration (pour les tokens OAuth, abonnements)
  expiresAt      DateTime?

  /// Date de la derniere utilisation reussie
  lastUsedAt     DateTime?

  /// Date de la derniere erreur
  lastErrorAt    DateTime?

  /// Message de la derniere erreur
  lastErrorMsg   String?

  /// Nombre d appels ce mois-ci (pour les quotas)
  monthlyCallCount Int             @default(0)

  /// Quota mensuel maximum d appels (null = illimite)
  monthlyQuota   Int?

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([organizationId, integrationId])
  @@index([organizationId])
  @@index([integrationId])
  @@index([status])
  @@map("organization_integrations")
}

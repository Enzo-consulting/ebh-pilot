# ============================================================
# EBH Pilot — Frontend environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# API (required)
# URL of the EBH Pilot API backend.
# Development : http://localhost:4000
# Production  : https://your-api.onrender.com
# ------------------------------------------------------------
VITE_API_URL="http://localhost:4000"

# ------------------------------------------------------------
# Application metadata (optional)
# Displayed in the browser tab title and startup logs.
# ------------------------------------------------------------
VITE_APP_NAME="EBH Pilot"

# ------------------------------------------------------------
# Environment (optional)
# One of: development | staging | production
# Defaults to the Vite build mode (development / production).
# ------------------------------------------------------------
VITE_ENVIRONMENT="development"

# ------------------------------------------------------------
# Supabase (required for authentication)
# ------------------------------------------------------------
VITE_SUPABASE_URL="https://[PROJECT].supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

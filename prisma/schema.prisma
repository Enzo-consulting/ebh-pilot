// PUBLIC PROFILE
// ============================================================

/// Profil public interne d'un utilisateur
model UserPublicProfile {
  id               String                @id @default(uuid())
  userId           String                @unique
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId   String
  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bio              String?
  avatarUrl        String?
  jobTitle         String?
  joinedAt         DateTime?
  customLinks      Json                  @default("[]")
  highlightedBadges Json                 @default("[]")
  visibility       ProfileVisibilityLevel @default(ORGANIZATION)
  isVisible        Boolean               @default(true)
  displayName      String?
  coverImageUrl    String?
  currentRank      Int?
  reputationScore  Decimal?              @db.Decimal(7, 2)
  totalSales       Int                   @default(0)
  totalClients     Int                   @default(0)
  totalProspects   Int                   @default(0)
  badgesVisible    Boolean               @default(true)
  achievementsVisible Boolean            @default(true)
  statisticsVisible   Boolean            @default(true)
  profileViews     Int                   @default(0)
  lastProfileView  DateTime?
  isPublicInsideOrganization Boolean     @default(true)
  lifetimeXp       Int                   @default(0)
  level            Int                   @default(1)
  totalXp          Int                   @default(0)
  metadata         Json                  @default("{}")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  profileVisits    ProfileVisit[]

  @@index([organizationId])
  @@index([organizationId, isVisible])
  @@map("user_public_profiles")
}

/// Configuration de visibilité des champs du profil par organisation
model ProfileFieldVisibility {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fieldKey       String
  isVisible      Boolean      @default(true)
  visibleTo      ProfileVisibilityLevel @default(ORGANIZATION)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, fieldKey])
  @@index([organizationId])
  @@map("profile_field_visibilities")
}

// ============================================================
// PROFILE VISITS
// ============================================================

/// Enregistrement des visites de profil
model ProfileVisit {
  id              String            @id @default(uuid())
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  visitorId       String?
  visitor         User?             @relation("ProfileVisitVisitor", fields: [visitorId], references: [id], onDelete: SetNull)
  profileId       String
  profile         UserPublicProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  visitedAt       DateTime          @default(now())
  metadata        Json              @default("{}")

  @@index([profileId])
  @@index([visitorId])
  @@index([organizationId])
  @@index([profileId, visitedAt])
  @@map("profile_visits")
}

/// Configuration du système de visite de profil par organisation
model ProfileVisitConfig {
  id              String       @id @default(uuid())
  organizationId  String       @unique
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isEnabled       Boolean      @default(true)
  isPremiumOnly   Boolean      @default(false)
  retentionDays   Int          @default(90)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("profile_visit_configs")
}

// ============================================================
// RECORDS ENGINE
// ============================================================

/// Définition d'un type de record (configurable, générique)
model RecordDefinition {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String
  name           String
  description    String?
  icon           String?
  color          String?      @default("#F59E0B")
  kpiCode        String?
  period         RecordPeriod
  scope          RecordScope
  isHigherBetter Boolean      @default(true)
  isActive       Boolean      @default(true)
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  records UserRecord[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@map("record_definitions")
}

/// Enregistrement d'un record atteint par un utilisateur
model UserRecord {
  id                 String           @id @default(uuid())
  organizationId     String
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordDefinitionId String
  recordDefinition   RecordDefinition @relation(fields: [recordDefinitionId], references: [id], onDelete: Cascade)
  value              Decimal          @db.Decimal(15, 4)
  previousValue      Decimal?         @db.Decimal(15, 4)
  isCurrent          Boolean          @default(true)
  isAllTime          Boolean          @default(false)
  periodStart        DateTime?
  periodEnd          DateTime?
  seasonId           String?
  season             Season?          @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  achievedAt         DateTime         @default(now())
  metadata           Json             @default("{}")
  createdAt          DateTime         @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([recordDefinitionId])
  @@index([userId, recordDefinitionId, isCurrent])
  @@index([organizationId, isAllTime])
  @@map("user_records")
}


  @@index([userId])
  @@index([badgeId])
  @@index([userId, earnedAt])
  @@map("user_badges")
}

model Challenge {
  id              String          @id @default(uuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  status          ChallengeStatus @default(DRAFT)
  type            ChallengeType   @default(INDIVIDUAL)
  kpiCode         String
  targetValue     Decimal?        @db.Decimal(15, 4)
  startDate       DateTime
  endDate         DateTime
  reward          Json?
  rules           Json?
  imageUrl        String?
  isPublic        Boolean         @default(true)
  maxParticipants Int?
  seasonId        String?
  season          Season?         @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  participants ChallengeParticipant[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, startDate, endDate])
  @@index([seasonId])
  @@map("challenges")
}

model ChallengeParticipant {
  id           String    @id @default(uuid())
  challengeId  String
  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  score        Decimal   @default(0) @db.Decimal(15, 4)
  position     Int?
  rewardEarned Json?
  joinedAt     DateTime  @default(now())
  lastScoredAt DateTime?

  @@unique([challengeId, userId])
  @@index([challengeId])
  @@index([userId])
  @@index([challengeId, position])
  @@map("challenge_participants")
}

model Goal {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  kpiCode        String
  name           String
  description    String?
  targetValue    Decimal      @db.Decimal(15, 4)
  period         GoalPeriod   @default(MONTHLY)
  startDate      DateTime
  endDate        DateTime
  status         GoalStatus   @default(ACTIVE)
  seasonId       String?
  season         Season?      @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  progress GoalProgress[]

  @@index([userId])
  @@index([organizationId])
  @@index([userId, status])
  @@index([userId, startDate, endDate])
  @@map("goals")
}

model GoalProgress {
  id           String   @id @default(uuid())
  goalId       String
  goal         Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  currentValue Decimal  @db.Decimal(15, 4)
  progressPct  Decimal  @db.Decimal(7, 2)
  projection   Decimal? @db.Decimal(15, 4)
  recordedAt   DateTime @default(now())

  @@index([goalId])
  @@index([goalId, recordedAt])
  @@map("goal_progress")
}

model Season {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean      @default(true)
  isArchived     Boolean      @default(false)
  color          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  kpiValues    UserKpiValue[]
  leaderboards Leaderboard[]
  challenges   Challenge[]
  goals        Goal[]
  userLeagues  UserLeague[]
  userLeaguePeaks UserLeaguePeak[]
  hallOfFameEntries HallOfFameEntry[]
  userRecords   UserRecord[]
  userStatSnapshots UserStatSnapshot[]
  userRewards   UserReward[]
  xpTransactions XpTransaction[]


  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([organizationId, startDate, endDate])
  @@map("seasons")
}

